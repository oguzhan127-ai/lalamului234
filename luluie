            if not abOn then return end
            local c = player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            if not h then return end

            local np, nd = nil, math.huge
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character then
                    local oh = p.Character:FindFirstChild("HumanoidRootPart")
                    local hum = p.Character:FindFirstChildOfClass("Humanoid")
                    if oh and hum and hum.Health > 0 then
                        local d = (h.Position - oh.Position).Magnitude
                        if d < nd then nd = d; np = p end
                    end
                end
            end

            if np and np.Character then
                local th = np.Character:FindFirstChild("HumanoidRootPart")
                if th then
                    abTarget = np

                    -- Block player input
                    local selfHum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
                    if selfHum then
                        selfHum.AutoRotate = false
                        selfHum:Move(Vector3.zero, false)
                    end

                    local targetVel = th.AssemblyLinearVelocity
