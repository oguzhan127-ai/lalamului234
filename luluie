                        thum:GetState() == Enum.HumanoidStateType.Ragdoll or
                        thum:GetState() == Enum.HumanoidStateType.FallingDown or
                        thum:GetState() == Enum.HumanoidStateType.Physics
                    )

                    -- Predict where target will be next frame (compensate network lag)
                    local PING_COMP = 0.05
                    local predictedPos = th.Position + targetVel * PING_COMP
                    local targetPos = predictedPos

                    local xDiff = targetPos.X - h.Position.X
                    local zDiff = targetPos.Z - h.Position.Z

                    -- XZ: copy target velocity + very strong correction
                    local xRaw = targetVel.X + xDiff * 60
                    local zRaw = targetVel.Z + zDiff * 60
                    local xzVec = Vector3.new(xRaw, 0, zRaw)
                    if xzVec.Magnitude > SPEED_VAL then
