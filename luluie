    lbl.TextSize = 11
    lbl.TextColor3 = Color3.fromRGB(190, 188, 210)
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    -- FIXED: line starts right after text, not far away. Uses TextService to measure text width.
    -- We use a small offset from text start + estimated text width
    -- Text is ~11px font, ~7px per char average for GothamBold
    local estimatedTextWidth = #text * 7 + 8  -- rough estimate for header line start
    local lineStartOffset = 16 + estimatedTextWidth + 10  -- 16 (bar+gap) + text width + small gap

    local hline = Instance.new("Frame", h)
    hline.Size = UDim2.new(1, -lineStartOffset, 0, 1)
    hline.Position = UDim2.new(0, lineStartOffset, 0.5, 0)
    hline.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    hline.BackgroundTransparency = 0.45
    hline.BorderSizePixel = 0
    local hlineGrad = Instance.new("UIGradient", hline)
    hlineGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(180, 160, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(160, 180, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(220, 220, 255)),
    })
    hlineGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.1),
        NumberSequenceKeypoint.new(1, 0.7),
    })
end

local function makeSwitch(parent, label, default, cb)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 46)
    row.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    row.BackgroundTransparency = 0
    row.Parent = parent
    corner(row, 8)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -72, 1, 0)
    lbl.Position = UDim2.new(0, 14, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextColor3 = C.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    -- Track
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(0, 46, 0, 26)
    track.Position = UDim2.new(1, -56, 0.5, -13)
    track.BorderSizePixel = 0
    corner(track, 13)

    -- FIXED: set track color AND gradient correctly based on default state
    if default then
        track.BackgroundColor3 = Color3.fromRGB(110, 60, 255)
    else
        track.BackgroundColor3 = Color3.fromRGB(40, 39, 52)
    end

    -- FIXED: UIGradient created with correct colors for current state, updated on toggle
    local trackGrad = Instance.new("UIGradient", track)
    if default then
        trackGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(155, 55, 255)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(100, 65, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(45, 130, 255))
        })
    else
        trackGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(48, 47, 60)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(32, 31, 42))
        })
    end

    -- Knob
