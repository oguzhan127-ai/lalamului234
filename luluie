-- DESYNC
do
    local DesyncActive = false

    -- RAKNET CORE
    local function RakNetLogic(packet)
        if DesyncActive and packet.PacketId == 27 then
            local data = packet.AsBuffer
            buffer.writeu32(data, 1, 0)
            packet:SetData(data)
        end
    end

    -- ANTI-RAGDOLL during desync
    RunService.Stepped:Connect(function()
        if DesyncActive and player.Character then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
                hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            end
        end
    end)

    local function setDesyncFFlags()
        local flags = {
            ["PhysicsSenderMaxBandwidthBps"] = "150000",
            ["S2PhysicsSenderRate"] = "80",
            ["GameNetDontSendRedundantDeltaPositionMillionth"] = "1",
            ["GameNetPVHeaderLinearVelocityZeroCutoffExponent"] = "-500",
        }
        for name, value in pairs(flags) do
            pcall(function() setfflag(name, value) end)
        end
    end

    local function enableDesync()
        DesyncActive = true
        setDesyncFFlags()
        pcall(function()
            if raknet then
                if raknet.desync then raknet.desync(true) end
                if raknet.add_send_hook then raknet.add_send_hook(RakNetLogic) end
            end
        end)
        -- Auto reset once after 0.8 seconds
        local _didReset = false
        task.delay(0.8, function()
            if not DesyncActive or _didReset then return end
            _didReset = true
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            if hrp and hum then
                hrp.CFrame = CFrame.new(1000003.62, 999998.38, 8.11)
                hum.Health = 0
            end
        end)
    end

    local function disableDesync()
        DesyncActive = false
        pcall(function()
            if raknet then
                if raknet.desync then raknet.desync(false) end
                if raknet.remove_send_hooks then raknet.remove_send_hooks() end
