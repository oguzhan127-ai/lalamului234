local _CFG = {}
pcall(function()
    local HttpService = game:GetService("HttpService")
    local content = nil
    local CFG_NAME = "UN4HUB_Config.json"
    if readfile then pcall(function() content = readfile(CFG_NAME) end) end
    if (not content or content == "") and fileread then pcall(function() content = fileread(CFG_NAME) end) end
    if (not content or content == "") and syn and syn.read_file then pcall(function() content = syn.read_file(CFG_NAME) end) end
    if content and content ~= "" then
        local ok, data = pcall(function() return HttpService:JSONDecode(content) end)
        if ok and data then _CFG = data end
    end
end)
local function _cfgGet(key, default)
    if _CFG[key] ~= nil then return _CFG[key] end
    return default
end
-- If platform changed (PC<->mobile), ignore saved button positions
local _platformChanged = (_CFG.wasMobile ~= nil) and (_CFG.wasMobile ~= UserInputService.TouchEnabled)
local function _cfgGetPos(key, default)
    if _platformChanged then return default end
    if _CFG[key] ~= nil then return _CFG[key] end
    return default
end
