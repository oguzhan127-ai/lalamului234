do
    -- ANTI FPS DEVOURER

    local function removeAccessories(char)
        if not char then return end
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("Accessory") or v:IsA("Hat") then
                pcall(function() v:Destroy() end)
            end
        end
    end

    local function removeShirts(char)
        if not char then return end
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") then
                pcall(function() v:Destroy() end)
            end
        end
    end

    local function applyToChar(char)
        if not antiFpsOn then return end
        removeAccessories(char)
        removeShirts(char)
        -- Disable particles on character
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then
                pcall(function() v.Enabled = false end)
            end
        end
    end

    local antiFpsConns = {}

    local function enableAntiFps()
        -- Apply to all current players
        for _, p in ipairs(Players:GetPlayers()) do
            local char = p.Character
            if char then applyToChar(char) end
            -- Watch for new characters
            antiFpsConns[p] = p.CharacterAdded:Connect(function(newChar)
                task.wait(0.5)
                if antiFpsOn then applyToChar(newChar) end
            end)
        end
        -- Watch for new players
        antiFpsConns["_added"] = Players.PlayerAdded:Connect(function(p)
            antiFpsConns[p] = p.CharacterAdded:Connect(function(newChar)
                task.wait(0.5)
                if antiFpsOn then applyToChar(newChar) end
            end)
            if p.Character and antiFpsOn then applyToChar(p.Character) end
        end)
    end

    local function disableAntiFps()
        for k, conn in pairs(antiFpsConns) do
            if conn and typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
            antiFpsConns[k] = nil
        end
    end

    _G._sw_antiFpsOn = makeSwitch(moveSection, "Anti FPS Devourer", _cfgGet("antiFpsOn", false), function(on)
        antiFpsOn = on
        if on then enableAntiFps() else disableAntiFps() end
    end)

    if _cfgGet("antiFpsOn", false) then antiFpsOn = true; task.defer(enableAntiFps) end
end

