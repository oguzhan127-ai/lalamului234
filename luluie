do
    -- ESP SYSTEM (Drawing-based, 1-1 from provided script with our theme)
    local espOn = false
    local espConns = {}

    local ESPTheme = {
        Box     = Color3.fromRGB(110, 70, 255),
        Tracer  = Color3.fromRGB(230, 210, 255),
        Name    = Color3.fromRGB(255, 255, 255),
        Dist    = Color3.fromRGB(230, 220, 255),
        HP      = Color3.fromRGB(110, 70, 255),
        HPBg    = Color3.fromRGB(0, 0, 0),
        Fill    = Color3.fromRGB(110, 70, 255),
        Outline = Color3.fromRGB(255, 255, 255),
        Thick   = 1.8,
    }

    local function createESP(p)
        if p == player then return end

        local BoxLines = {}
        -- 4 shadow copies per line (offset up/down/left/right = visible stroke)
        local BoxShadows = {} -- [i] = 8 directional shadows
        for i = 1, 8 do
            local group = {}
            for _ = 1, 8 do
                local s = Drawing.new("Line")
                s.Thickness = ESPTheme.Thick + 2
                s.Color = Color3.fromRGB(0, 0, 0)
                s.Transparency = 0
                s.ZIndex = 6
                s.Visible = false
                table.insert(group, s)
            end
            BoxShadows[i] = group
        end
        for i = 1, 8 do
            local l = Drawing.new("Line")
            l.Thickness = ESPTheme.Thick
            l.Color = ESPTheme.Box
            l.ZIndex = 7
            l.Visible = false
            BoxLines[i] = l
        end

        local Tracer  = Drawing.new("Line")
        Tracer.Color = ESPTheme.Box
        Tracer.Thickness = 2
        Tracer.Transparency = 0.7
        Tracer.ZIndex = 4
        Tracer.Visible = false

        local NameDraw = Drawing.new("Text")
        NameDraw.Size = 13
        NameDraw.Color = ESPTheme.Name
        NameDraw.Center = true
        NameDraw.Outline = true
        NameDraw.OutlineColor = Color3.fromRGB(0,0,0)
        NameDraw.Font = 2
        NameDraw.ZIndex = 6
        NameDraw.Visible = false

        local DistDraw = Drawing.new("Text")
        DistDraw.Size = 11
        DistDraw.Color = ESPTheme.Dist
        DistDraw.Center = true
        DistDraw.Outline = true
        DistDraw.OutlineColor = Color3.fromRGB(0,0,0)
        DistDraw.ZIndex = 6
        DistDraw.Visible = false

        -- HP bar as BillboardGui (works properly on mobile and PC)
        -- HP bar as ScreenGui Frame positioned at ESP box location
        local hpSGui = Instance.new("ScreenGui")
        hpSGui.ResetOnSpawn = false
        hpSGui.IgnoreGuiInset = true
        hpSGui.DisplayOrder = 997
        hpSGui.Parent = player:WaitForChild("PlayerGui")

        local hpBgFrame = Instance.new("Frame", hpSGui)
        hpBgFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        hpBgFrame.BorderSizePixel = 0
        hpBgFrame.Visible = false
        local _hpStroke = Instance.new("UIStroke", hpBgFrame)
        _hpStroke.Color = Color3.fromRGB(0,0,0)
        _hpStroke.Thickness = 1
        _hpStroke.Transparency = 0

        local hpFill = Instance.new("Frame", hpBgFrame)
        hpFill.BackgroundColor3 = ESPTheme.HP
        hpFill.BorderSizePixel = 0
        hpFill.AnchorPoint = Vector2.new(0, 1)
        hpFill.Position = UDim2.new(0, 0, 1, 0)
        hpFill.Size = UDim2.new(1, 0, 0, 0) -- starts empty, updated each frame

        local hpGui = {Enabled=false}
        local HPBg = {Visible=false, Remove=function() end}
        local HPBar = {Visible=false, Remove=function() end}
        HPBar.Visible = false

        local hl = Instance.new("Highlight")
        hl.Parent = game:GetService("CoreGui")
        hl.FillColor = ESPTheme.Fill
        hl.FillTransparency = 0.6
        hl.OutlineColor = ESPTheme.Outline
        hl.OutlineTransparency = 0.15
        hl.Enabled = false

        local cam = workspace.CurrentCamera
        local conn
        conn = RunService.RenderStepped:Connect(function()
            local char = p.Character
            local myChar = player.Character
            if char and char:FindFirstChild("HumanoidRootPart")
            and myChar and myChar:FindFirstChild("HumanoidRootPart") then
                local root = char.HumanoidRootPart
                local hum  = char:FindFirstChild("Humanoid")
                local pos, onScreen = cam:WorldToViewportPoint(root.Position)
                local myRoot = myChar.HumanoidRootPart
                local myPos  = cam:WorldToViewportPoint(myRoot.Position)

                if onScreen and espOn then
                    -- Separate sizing for mobile and PC
                    local scale = 1 / (pos.Z * math.tan(math.rad(cam.FieldOfView * 0.5)) * 2) * 1000
                    local w, h
                    if isMobile then
                        w = math.clamp(4 * scale, 14, 42)
                        h = math.clamp(5.5 * scale, 20, 58)
                    else
                        w = math.clamp(4 * scale, 35, 90)
                        h = math.clamp(5.5 * scale, 50, 130)
                    end
                    local x, y = pos.X - w/2, pos.Y - h/2
                    local cl = w * 0.22

                    -- Corner box
                    local corners = {
                        {Vector2.new(x,y),     Vector2.new(x+cl,y)},
                        {Vector2.new(x,y),     Vector2.new(x,y+cl)},
                        {Vector2.new(x+w,y),   Vector2.new(x+w-cl,y)},
                        {Vector2.new(x+w,y),   Vector2.new(x+w,y+cl)},
                        {Vector2.new(x,y+h),   Vector2.new(x+cl,y+h)},
                        {Vector2.new(x,y+h),   Vector2.new(x,y+h-cl)},
                        {Vector2.new(x+w,y+h), Vector2.new(x+w-cl,y+h)},
                        {Vector2.new(x+w,y+h), Vector2.new(x+w,y+h-cl)},
                    }
                    local lineThick = isMobile and 2.5 or 1.8
                    for _,l in ipairs(BoxLines) do l.Thickness = lineThick end
                    for _,g in ipairs(BoxShadows) do for _,s in ipairs(g) do s.Thickness = lineThick + 2 end end
                    local off = isMobile and 2 or 2.5
                    local offsets = {
                        Vector2.new(0,-off), Vector2.new(0,off),
                        Vector2.new(-off,0), Vector2.new(off,0),
                        Vector2.new(-off,-off), Vector2.new(off,-off),
                        Vector2.new(-off,off), Vector2.new(off,off)
                    }
                    for i, pts in ipairs(corners) do
                        for j, o in ipairs(offsets) do
                            BoxShadows[i][j].From = pts[1]+o; BoxShadows[i][j].To = pts[2]+o; BoxShadows[i][j].Visible = true
                        end
                        BoxLines[i].From = pts[1]; BoxLines[i].To = pts[2]; BoxLines[i].Visible = true
                    end

                    -- TRACER (1-1 from script)
                    local MyRoot = myChar.HumanoidRootPart
                    local MyPos = cam:WorldToViewportPoint(MyRoot.Position)
                    Tracer.Visible = true
                    Tracer.From = Vector2.new(MyPos.X, MyPos.Y)
                    Tracer.To = Vector2.new(pos.X, pos.Y)
                    Tracer.Color = ESPTheme.Box
                    Tracer.Thickness = 2
                    Tracer.Transparency = 0.7

                    -- Name above box (fixed offset, not zoom scaled)
                    NameDraw.Text = p.Name
                    NameDraw.Position = Vector2.new(pos.X, y - 25)
                    NameDraw.Visible = true

                    -- Distance below box (fixed offset)
                    local dist = math.floor((myRoot.Position - root.Position).Magnitude)
                    DistDraw.Text = dist.." studs"
                    DistDraw.Position = Vector2.new(pos.X, y + h + 5)
                    DistDraw.Visible = true

                    if hum then
                        local hpPct = hum.Health / math.max(hum.MaxHealth, 1)
                        local barW = isMobile and 2 or 3
                        local barX = x - barW - 2
                        hpBgFrame.Position = UDim2.new(0, barX, 0, y)
                        hpBgFrame.Size = UDim2.new(0, barW, 0, h)
                        hpBgFrame.Visible = true
                        hpFill.Size = UDim2.new(1, 0, hpPct, 0)
                    end

                    -- Highlight glow
                    hl.Adornee = char
                    hl.Enabled = true
                else
                    for i,l in ipairs(BoxLines) do l.Visible = false; for _,s in ipairs(BoxShadows[i]) do s.Visible = false end end
                    Tracer.Visible = false
                    NameDraw.Visible = false
                    DistDraw.Visible = false
                    hpBgFrame.Visible = false
                    hl.Enabled = false
                end

                if not p.Parent then
                    for i,l in ipairs(BoxLines) do l:Remove(); for _,s in ipairs(BoxShadows[i]) do s:Remove() end end
                    Tracer:Remove(); NameDraw:Remove(); DistDraw:Remove()
                    HPBg:Remove(); HPBar:Remove(); hl:Destroy()
                    conn:Disconnect()
                end
            else
                for i,l in ipairs(BoxLines) do l.Visible = false; for _,s in ipairs(BoxShadows[i]) do s.Visible = false end end
                Tracer.Visible = false; NameDraw.Visible = false
                DistDraw.Visible = false; HPBg.Visible = false; HPBar.Visible = false
                hpBgFrame.Visible = false
                hl.Enabled = false
                if not p.Parent then
                    for i,l in ipairs(BoxLines) do l:Remove(); for _,s in ipairs(BoxShadows[i]) do s:Remove() end end
                    Tracer:Remove(); NameDraw:Remove(); DistDraw:Remove()
                    HPBg:Remove(); HPBar:Remove(); hl:Destroy()
                    hpBgFrame.Visible = false
                    conn:Disconnect()
                end
            end
        end)
        table.insert(espConns, conn)
    end

    Players.PlayerAdded:Connect(createESP)
    Players.PlayerRemoving:Connect(function(p)
        local d = espData[p]
        if d then
            if d.hpBgFrame then d.hpBgFrame.Visible = false end
            if d.line then d.line.Visible = false end
        end
        task.defer(function() removeESP(p) end)
    end)

    -- Also watch for character removal (reset)
    local function watchChar(p)
        if p == player then return end
        p.CharacterRemoving:Connect(function()
            local d = espData[p]
            if d then
                if d.hpBgFrame then d.hpBgFrame.Visible = false end
                if d.line then d.line.Visible = false end
                if d.bb then d.bb.Enabled = false end
            end
        end)
    end
    for _, p in ipairs(Players:GetPlayers()) do watchChar(p) end
    Players.PlayerAdded:Connect(function(p)
        createESP(p)
        watchChar(p)
    end)

    toggleSetters._getEspOn = function() return espOn end
    _G._sw_espOn = makeSwitch(moveSection, "ESP", _cfgGet("espOn", false), function(on)
        espOn = on
        if on then
            for _, p in ipairs(Players:GetPlayers()) do
                createESP(p)
            end
