do
    -- NO CAMERA COLLISION
    local nccOn = false
    local nccConn = nil

    local nccActive = {}   -- parts currently made transparent
    local nccPrev = {}    -- parts made transparent last frame

    local function enableNCC()
        if nccConn then return end
        nccConn = RunService.RenderStepped:Connect(function()
            if not nccOn then return end
            local cam = workspace.CurrentCamera
            local camPos = cam.CFrame.Position
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hitSet = {} -- obj -> target transparency

            local params = RaycastParams.new()
            params.FilterType = Enum.RaycastFilterType.Exclude
            if char then params.FilterDescendantsInstances = {char} end

            if hrp then
                local origin = camPos
                local target = hrp.Position
                local totalDist = (target - origin).Magnitude

                for _ = 1, 20 do
                    local dir = target - origin
                    if dir.Magnitude < 0.1 then break end
                    local result = workspace:Raycast(origin, dir, params)
                    if not result then break end
                    local obj = result.Instance
                    if obj and obj:IsA("BasePart") then
                        -- Only fade when camera is very close to or inside the part
                        local distFromCam = (result.Position - camPos).Magnitude
                        -- Only affect parts within 1.5 studs of the camera
                        if distFromCam > 1.5 then
                            origin = result.Position + dir.Unit * 0.05
                            continue
                        end
                        local targetTrans = math.clamp(1 - distFromCam / 1.5, 0, 1)
                        if not hitSet[obj] or hitSet[obj] < targetTrans then
                            hitSet[obj] = targetTrans
                        end
                        if not nccActive[obj] then nccActive[obj] = obj.LocalTransparencyModifier end
                    end
                    origin = result.Position + dir.Unit * 0.05
                end
            end

            -- Very close to camera (inside part): fully invisible
            local R = 2
            local region = Region3.new(camPos - Vector3.new(R,R,R), camPos + Vector3.new(R,R,R))
            local nearParts = workspace:FindPartsInRegion3(region, char, 20)
            for _, obj in ipairs(nearParts) do
                if obj:IsA("BasePart") then
                    hitSet[obj] = 1
                    if not nccActive[obj] then nccActive[obj] = obj.LocalTransparencyModifier end
                end
            end

            -- Apply transparencies smoothly
            for obj, targetTrans in pairs(hitSet) do
                if obj and obj.Parent then
                    local cur = obj.LocalTransparencyModifier
                    obj.LocalTransparencyModifier = cur + (targetTrans - cur) * 0.2
                end
            end

            -- Restore parts no longer in hitSet
            for obj, val in pairs(nccActive) do
                if not hitSet[obj] then
                    if obj and obj.Parent then
                        local cur = obj.LocalTransparencyModifier
                        local restored = cur + (val - cur) * 0.2
                        obj.LocalTransparencyModifier = restored
                        if math.abs(restored - val) < 0.01 then
                            obj.LocalTransparencyModifier = val
                            nccActive[obj] = nil
                        end
                    else
                        nccActive[obj] = nil
                    end
                end
            end
        end)
    end

    local function disableNCC()
        if nccConn then nccConn:Disconnect(); nccConn = nil end
        for obj, val in pairs(nccPrev) do
            if obj and obj.Parent then pcall(function() obj.LocalTransparencyModifier = val end) end
        end
        for obj, val in pairs(nccActive) do
            if obj and obj.Parent then pcall(function() obj.LocalTransparencyModifier = val end) end
        end
        nccPrev = {}
        nccActive = {}
    end

    _G._sw_nccOn = makeSwitch(moveSection, "No Camera Collision", _cfgGet("nccOn", false), function(on)
        nccOn = on
        if on then enableNCC() else disableNCC() end
    end)
    toggleSetters._getNccOn = function() return nccOn end
    if _cfgGet("nccOn", false) then nccOn = true; task.defer(enableNCC) end
end

