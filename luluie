-- Runs every heartbeat, forces AutoRotate=false AND exact face direction
RunService.Heartbeat:Connect(function()
    if not _apRunning then return end
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if hum and hum.AutoRotate then hum.AutoRotate = false end
    local _spinActive = toggleSetters._getSpinOn and toggleSetters._getSpinOn() or false
    -- Gentle face direction: only correct if significantly off
    if root and _goFaceLock and not (toggleSetters._getSpinOn and toggleSetters._getSpinOn()) then
        local currentLook = Vector3.new(root.CFrame.LookVector.X, 0, root.CFrame.LookVector.Z)
        if currentLook.Magnitude > 0.01 then
            local dot = currentLook.Unit:Dot(_goFaceLock)
            if dot < 0.98 then
                local p = root.Position
                root.CFrame = CFrame.new(p, p + _goFaceLock)
            end
        end
    end
end)

