local activeTab  = nil

local function makeSection(name)
    local sf = Instance.new("ScrollingFrame")
    sf.Name = name
    sf.Size = UDim2.new(1, -10, 1, -8)
    sf.Position = UDim2.new(0, 5, 0, 4)
    sf.BackgroundTransparency = 1
    sf.CanvasSize = UDim2.new(0, 0, 0, 0)
    sf.ScrollBarThickness = isMobile and 0 or 2
    sf.ScrollBarImageColor3 = Color3.fromRGB(180, 178, 200)
    sf.VerticalScrollBarInset = Enum.ScrollBarInset.ScrollBar
    sf.ScrollingEnabled = true
    sf.ScrollingDirection = Enum.ScrollingDirection.Y
    sf.Visible = false
    sf.Parent = content
    local lay = Instance.new("UIListLayout", sf)
    lay.Padding = UDim.new(0, 7)
    lay.FillDirection = Enum.FillDirection.Vertical
    lay.HorizontalAlignment = Enum.HorizontalAlignment.Center
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    Instance.new("UIPadding", sf).PaddingTop = UDim.new(0, 6)
    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local extraScale = isMobile and (1/0.72) or 1
        sf.CanvasSize = UDim2.new(0, 0, 0, (lay.AbsoluteContentSize.Y + 16) * extraScale)
    end)
    sections[name] = sf
    return sf
end

local sharedInd = nil

local function switchTab(name)
    if activeTab == name then return end
    if activeTab then
        if sections[activeTab] then sections[activeTab].Visible = false end
        if tabBtns[activeTab] then
            tw(tabBtns[activeTab].btn, 0.15, {BackgroundTransparency = 1})
            tw(tabBtns[activeTab].lbl, 0.15, {TextColor3 = Color3.fromRGB(120,118,140)})
        end
    end
    activeTab = name
    if sections[name] then sections[name].Visible = true end
    if tabBtns[name] then
        tabBtns[name].btn.BackgroundTransparency = 0
        tw(tabBtns[name].btn, 0.15, {BackgroundColor3 = Color3.fromRGB(22, 22, 28)})
        tw(tabBtns[name].lbl, 0.15, {TextColor3 = Color3.fromRGB(255,255,255)})
        if sharedInd then
            task.spawn(function()
                task.wait()
                local sc = isMobile and (1/0.72) or 1
                local btnAbs  = tabBtns[name].btn.AbsolutePosition
                local mainAbs = main.AbsolutePosition
                local btnH    = tabBtns[name].btn.AbsoluteSize.Y
                local indH    = sharedInd.AbsoluteSize.Y
                local newY    = ((btnAbs.Y - mainAbs.Y) + math.floor((btnH - indH) / 2)) * sc
                TweenService:Create(sharedInd,
                    TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                    {Position = UDim2.new(0, 2, 0, newY)}
                ):Play()
            end)
        end
    end
end

