            while IsStealing do
                local prog = math.clamp((tick()-t0)/dur, 0, 1)
                hudBarFill.Size = UDim2.new(prog, 0, 1, 0)
                if prog >= 1 then
                    task.wait(0.04)
                    hudBarFill.Size = UDim2.new(0, 0, 1, 0)
                    t0 = tick()
                end
                task.wait(0)
            end
            hudBarFill.Size = UDim2.new(0, 0, 1, 0)
        end
        pbAnimConn = nil
    end)
end

