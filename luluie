do
    local atOn         = false
    local atConn       = nil
    local atIsTping    = false
    local atHasRec     = true
    local atCharConn   = nil

    local AT_FINAL_POS1   = Vector3.new(-483.59, -5.04, 104.24)
    local AT_FINAL_POS2   = Vector3.new(-483.51, -5.10, 18.89)
    local AT_CHECKPOINT_A = Vector3.new(-472.60, -7.00, 57.52)
    local AT_CHECKPOINT_B1 = Vector3.new(-472.65, -7.00, 95.69)
    local AT_CHECKPOINT_B2 = Vector3.new(-471.76, -7.00, 26.22)

    local function atMove(pos)
        local char = player.Character
        if not char then return end
        char:PivotTo(CFrame.new(pos))
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end
    end

    local function atDetectSide()
        local plots = workspace:FindFirstChild("Plots")
        if plots then
            for _, plot in ipairs(plots:GetChildren()) do
                local result = nil
                pcall(function()
                    local sign = plot:FindFirstChild("PlotSign")
                    if not sign then return end
                    local yb = sign:FindFirstChild("YourBase")
                    if yb and yb:IsA("BillboardGui") and yb.Enabled then
                        local pivot = plot:GetPivot()
                        result = pivot.Position.Z > 50 and "Right" or "Left"
                    end
                end)
                if result then return result end
            end
        end
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            return root.Position.Z > 50 and "Right" or "Left"
        end
        return "Left"
    end

    local function atExecuteSequence(side)
        atIsTping  = true
        atHasRec   = false

        local targetB     = (side == "Left") and AT_CHECKPOINT_B1 or AT_CHECKPOINT_B2
        local targetFinal = (side == "Left") and AT_FINAL_POS1    or AT_FINAL_POS2

        atMove(AT_CHECKPOINT_A)
        task.wait(0.12)
        atMove(targetB)
        task.wait(0.12)
        atMove(targetFinal)

        atIsTping = false
    end

    local function atIsRagdoll(hum)
        if not hum then return false end
        local s = hum:GetState()
        return s == Enum.HumanoidStateType.Physics
            or s == Enum.HumanoidStateType.Ragdoll
            or s == Enum.HumanoidStateType.FallingDown
    end

    local function enableAT()
        if atOn then return end
        atOn      = true
        atIsTping = false
        atHasRec  = true

        atConn = RunService.Heartbeat:Connect(function()
            if not atOn then return end
            local char = player.Character
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if not hum then return end

            local ragged = atIsRagdoll(hum)

            if not ragged then
                atHasRec = true
            end

            if not atIsTping and atHasRec and ragged then
                local side = atDetectSide()
                task.spawn(function()
                    atExecuteSequence(side)
                end)
            end
        end)

        atCharConn = player.CharacterAdded:Connect(function()
            atIsTping = false
            atHasRec  = true
        end)
    end

    local function disableAT()
        if not atOn then return end
        atOn = false
        if atConn     then atConn:Disconnect();     atConn     = nil end
        if atCharConn then atCharConn:Disconnect(); atCharConn = nil end
        atIsTping = false
        atHasRec  = true
    end

    do
