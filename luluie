-- MELEE AIMBOT
do
    local maOn         = false
    local maConn       = nil
    local MA_RANGE     = _cfgGet("maRange", 20)

    local maAttachment = Instance.new("Attachment")
    local maAlign      = Instance.new("AlignOrientation")
    maAlign.Mode                = Enum.OrientationAlignmentMode.OneAttachment
    maAlign.Attachment0         = maAttachment
    maAlign.RigidityEnabled     = false
    maAlign.MaxAngularVelocity  = 15.4
    maAlign.MaxTorque           = 1000000
    maAlign.Responsiveness      = 200
    maAlign.Enabled             = false

    local function maGetTarget()
        local target, shortest = nil, MA_RANGE
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not root then return nil end
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    local d = (root.Position - p.Character.HumanoidRootPart.Position).Magnitude
                    if d < shortest then shortest = d; target = p.Character.HumanoidRootPart end
                end
            end
        end
        return target
    end

    local function enableMA()
        if maOn then return end
        maOn = true

        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            maAttachment.Parent = root
            maAlign.Parent = root
        end

        maConn = RunService.RenderStepped:Connect(function()
            if not maOn then return end
            -- Auto play is running: stay completely silent, dont touch anything
            if _apRunning then return end

            local c   = player.Character
            local root = c and c:FindFirstChild("HumanoidRootPart")
            local hum  = c and c:FindFirstChild("Humanoid")
            if not root or not hum then return end

            local target = maGetTarget()
            if target then
                hum.AutoRotate = false
                maAlign.Enabled = true

                local targetPos = target.Position + (target.AssemblyLinearVelocity * 0.12)
                local direction = (targetPos - root.Position).Unit
                local lookAt = CFrame.lookAt(Vector3.zero, Vector3.new(direction.X, 0, direction.Z))
                maAlign.CFrame = lookAt
            else
                maAlign.Enabled = false
                if not _apRunning then hum.AutoRotate = true end
            end
        end)

        player.CharacterAdded:Connect(function(char)
            local root = char:WaitForChild("HumanoidRootPart", 5)
            if root and maOn then
                maAttachment.Parent = root
                maAlign.Parent = root
            end
        end)
    end

    local function disableMA()
        if not maOn then return end
        maOn = false
        if maConn then maConn:Disconnect(); maConn = nil end
        maAlign.Enabled = false
        maAlign.Parent = nil
        maAttachment.Parent = nil
        local c   = player.Character
        local hum = c and c:FindFirstChild("Humanoid")
        if hum then hum.AutoRotate = true end
    end

    local function disableMAForAP()
        if not maOn then return end
        maOn = false
        if maConn then maConn:Disconnect(); maConn = nil end
        maAlign.Enabled = false
        maAlign.Parent = nil
        maAttachment.Parent = nil
    end

    toggleSetters._disableMA = disableMAForAP
    toggleSetters._getMAOn   = function() return maOn end

    local maSwitch, _ = makeInputSwitch(moveSection, "Melee Aimbot", MA_RANGE, 1, 200,
        function(v) MA_RANGE = v end,
        _cfgGet("maOn", false),
        function(on) if _apRunning and on then return end; if on then enableMA() else disableMA() end end)
    _G._maSwitch = maSwitch
    toggleSetters.maOn = function(v)
        if v and _apRunning then return end
        maSwitch.set(v, true)
    end
    _G._sw_maOn = maSwitch

    if _cfgGet("maOn", false) then task.defer(function() enableMA() end) end
end






-- UNWALK
do
    local uwOn   = false
    local uwConn = nil
    local uwCharConn = nil

    local MOVEMENT_KEYWORDS = {
        "walk", "run", "idle", "fall", "jump", "climb", "swim",
        "land", "sit", "animate", "stand", "strafe", "turn"
    }

    local function isMovementTrack(track)
        local name = track.Name:lower()
        for _, kw in ipairs(MOVEMENT_KEYWORDS) do
            if name:find(kw) then return true end
        end
        if track.Priority == Enum.AnimationPriority.Core
        or track.Priority == Enum.AnimationPriority.Idle then
            return true
        end
        return false
    end

    local function stopMovementAnims(char)
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local anim = hum:FindFirstChildOfClass("Animator")
        if not anim then return end
        for _, t in ipairs(anim:GetPlayingAnimationTracks()) do
            pcall(function()
                if isMovementTrack(t) then
                    t:Stop(0)
                end
            end)
        end
    end

    local function enableUW()
        if uwOn then return end
        uwOn = true
        stopMovementAnims(player.Character)
        uwConn = RunService.Heartbeat:Connect(function()
            if not uwOn then return end
            local char = player.Character
            if not char then return end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end
            local anim = hum:FindFirstChildOfClass("Animator")
            if not anim then return end
            for _, t in ipairs(anim:GetPlayingAnimationTracks()) do
                pcall(function()
                    if isMovementTrack(t) then
                        t:Stop(0)
                    end
                end)
            end
        end)
        uwCharConn = player.CharacterAdded:Connect(function(char)
            task.wait(0.5)
            if uwOn then stopMovementAnims(char) end
        end)
    end

    local function disableUW()
        if not uwOn then return end
        uwOn = false
        if uwConn     then uwConn:Disconnect();     uwConn     = nil end
        if uwCharConn then uwCharConn:Disconnect(); uwCharConn = nil end
    end

    local uwSwitch = makeSwitch(moveSection, "Unwalk", _cfgGet("uwOn", false), function(on)
        if on then enableUW() else disableUW() end
    end)
    toggleSetters.uwOn     = function(v) uwSwitch.set(v, true) end
    _G._sw_uwOn = uwSwitch
    toggleSetters._getUWOn = function() return uwOn end
    if _cfgGet("uwOn", false) then task.defer(function() enableUW() end) end
end

-- AUTO MEDUSA
do
    local amOn = false
    local AM_RANGE = _cfgGet("amRange", 10)

    -- Range indicator circle
    -- Line circle made of many thin parts in a ring
    local amRingFolder = Instance.new("Folder")
    amRingFolder.Name = "UN4_MedusaRing"
    amRingFolder.Parent = workspace

    local RING_SEGMENTS = 40
    local amRingParts = {}
    for i = 1, RING_SEGMENTS do
        local seg = Instance.new("Part")
        seg.Size = Vector3.new(0.14, 0.14, 1)
        seg.Anchored = true
        seg.CanCollide = false
        seg.CanQuery = false
        seg.CanTouch = false
        seg.CastShadow = false
        seg.Material = Enum.Material.Neon
        seg.Color = Color3.fromRGB(95, 85, 255)
        seg.Transparency = 0.15
        seg.Parent = amRingFolder
        amRingParts[i] = seg
    end

    RunService.RenderStepped:Connect(function()
        local visible = amOn
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not visible or not hrp then
            for _, seg in ipairs(amRingParts) do seg.Transparency = 1 end
            return
        end
        local r = AM_RANGE
        local segLen = 2 * math.pi * r / RING_SEGMENTS * 1.05
        local baseY = hrp.Position.Y - 2.5
        for i, seg in ipairs(amRingParts) do
            local angle = (i / RING_SEGMENTS) * 2 * math.pi
            local x = hrp.Position.X + r * math.cos(angle)
            local z = hrp.Position.Z + r * math.sin(angle)
            seg.Size = Vector3.new(0.14, 0.14, segLen)
            seg.CFrame = CFrame.lookAt(Vector3.new(x, baseY, z), Vector3.new(hrp.Position.X, baseY, hrp.Position.Z)) * CFrame.Angles(0, math.pi/2, 0)
            seg.Transparency = 0.15
        end
    end)

    local medusaNames = { ["medusa's head"]=true, ["medusa"]=true }
    local amCounterConn    = nil
    local amToolConns      = {}
    local amPlayerConns    = {}
    local lastMedusaUse    = 0
    local lastBoogieUse    = 0

    local function isMedusaToolName(name)
        if not name then return false end
        local lower = name:lower()
        if medusaNames[lower] then return true end
        return lower:find("medusa") ~= nil
    end

    local function isBoogieName(name)
        if not name then return false end
        return name:lower():find("boogie") ~= nil
    end

    local function safeDisc(conn)
        if conn and typeof(conn) == "RBXScriptConnection" then
            pcall(function() conn:Disconnect() end)
        end
    end

    local function getMedusaTool()
        local char = player.Character
        if char then
            for _, i in ipairs(char:GetChildren()) do
                if i:IsA("Tool") and isMedusaToolName(i.Name) then return i end
            end
        end
        local bp = player:FindFirstChildOfClass("Backpack")
        if bp then
            for _, i in ipairs(bp:GetChildren()) do
                if i:IsA("Tool") and isMedusaToolName(i.Name) then return i end
            end
        end
    end

    local function getBoogieTool()
        local char = player.Character
        if char then
            for _, i in ipairs(char:GetChildren()) do
                if i:IsA("Tool") and isBoogieName(i.Name) then return i end
            end
        end
        local bp = player:FindFirstChildOfClass("Backpack")
        if bp then
            for _, i in ipairs(bp:GetChildren()) do
                if i:IsA("Tool") and isBoogieName(i.Name) then return i end
            end
        end
    end

    local function enemyHasMedusa(character)
        if not character then return false end
        for _, i in ipairs(character:GetChildren()) do
            if i:IsA("Tool") and isMedusaToolName(i.Name) then return true end
        end
        return false
    end

    local function activateMedusa(tool)
        if not tool then return end
        local now = workspace:GetServerTimeNow()
        if now - lastMedusaUse <= 0.3 then return end
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if tool.Parent ~= player.Character then pcall(function() hum:EquipTool(tool) end) end
        pcall(function() if type(tool.Activate) == "function" then tool:Activate() end end)
        lastMedusaUse = now
        task.delay(0.1, function()
            local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            if h then pcall(function() h:UnequipTools() end) end
        end)
    end

    local function activateBoogie(tool)
        if not tool then return end
        local now = workspace:GetServerTimeNow()
        if now - lastBoogieUse <= 0.3 then return end
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if tool.Parent ~= player.Character then pcall(function() hum:EquipTool(tool) end) end
        pcall(function() if type(tool.Activate) == "function" then tool:Activate() end end)
        lastBoogieUse = now
        task.delay(0.1, function()
            local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            if h then pcall(function() h:UnequipTools() end) end
        end)
    end

    local function useCounterTool()
        local now = workspace:GetServerTimeNow()
        if now - lastMedusaUse > 0.3 then
            local t = getMedusaTool()
            if t then activateMedusa(t); return true end
        end
        if now - lastBoogieUse > 0.3 then
            local t = getBoogieTool()
            if t then activateBoogie(t); return true end
        end
        return false
    end

    local function unbindMedusaTool(tool)
        if amToolConns[tool] then
            safeDisc(amToolConns[tool])
            amToolConns[tool] = nil
        end
    end

    local function bindMedusaTool(tool)
        if not tool or not tool:IsA("Tool") or amToolConns[tool] then return end
        if not isMedusaToolName(tool.Name) then return end
        local conn = tool.Activated:Connect(function()
            if not amOn then return end
            local attackerRoot = tool.Parent and tool.Parent:FindFirstChild("HumanoidRootPart")
            local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not (attackerRoot and myHRP) then return end
            if (attackerRoot.Position - myHRP.Position).Magnitude <= 20 then
                useCounterTool()
            end
        end)
        amToolConns[tool] = conn
        tool.Destroying:Connect(function() unbindMedusaTool(tool) end)
    end

    local function unbindPlayerMedusa(plr)
        local list = amPlayerConns[plr]
        if list then
            for _, c in ipairs(list) do safeDisc(c) end
            amPlayerConns[plr] = nil
        end
    end

    local function bindPlayerMedusa(plr)
        if not plr or plr == player then return end
        unbindPlayerMedusa(plr)
        local conns = {}
        local function scan(char)
            if not char then return end
            for _, child in ipairs(char:GetChildren()) do
                if child:IsA("Tool") then bindMedusaTool(child) end
            end
            table.insert(conns, char.ChildAdded:Connect(function(obj)
                if obj:IsA("Tool") then bindMedusaTool(obj) end
            end))
        end
        local ok, cChar = pcall(function() return plr.Character or plr.CharacterAdded:Wait() end)
        if ok and cChar then scan(cChar) end
        table.insert(conns, plr.CharacterAdded:Connect(function(c) scan(c) end))
        amPlayerConns[plr] = conns
    end

    local function enableAM()
        if amOn then return end
        amOn = true
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player then bindPlayerMedusa(plr) end
        end
        amPlayerConns["_added"] = Players.PlayerAdded:Connect(bindPlayerMedusa)
        amCounterConn = RunService.Heartbeat:Connect(function()
            if not amOn then return end
            local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not myHRP then return end
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= player then
                    local ch = plr.Character
                    local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
                    if hrp and enemyHasMedusa(ch) then
                        if (hrp.Position - myHRP.Position).Magnitude <= AM_RANGE then
                            useCounterTool(); break
                        end
                    end
                end
            end
        end)
    end

    local function disableAM()
        if not amOn then return end
        amOn = false
        if amCounterConn then safeDisc(amCounterConn); amCounterConn = nil end
        if amPlayerConns["_added"] then safeDisc(amPlayerConns["_added"]); amPlayerConns["_added"] = nil end
        for tool, _ in pairs(amToolConns) do unbindMedusaTool(tool) end
        for plr, _ in pairs(amPlayerConns) do
            if plr ~= "_added" then unbindPlayerMedusa(plr) end
        end
    end

    toggleSetters._getAmOn = function() return amOn end
    _G._sw_amOn = makeSwitch(moveSection, "Auto Medusa", _cfgGet("amOn", false), function(on)
        if on then enableAM() else disableAM() end
    end)
    if _cfgGet("amOn", false) then task.defer(enableAM) end
end

