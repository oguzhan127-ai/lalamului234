        Color3.fromRGB(160, 60, 255),
        Color3.fromRGB(255, 210, 40),
    }

    local function makeWaypointPart(pos, color, label)
        local part = Instance.new("Part")
        part.Size = Vector3.new(2, 6, 2)
        part.CFrame = CFrame.new(Vector3.new(pos.X, -6 - 2.7, pos.Z))
        part.Anchored = true
        part.CanCollide = false
        part.CastShadow = false
        part.Material = Enum.Material.Neon
        part.Color = color
        part.Transparency = 0.3
        part.Name = "UN4G_Waypoint"
        part.Parent = workspace

        local bb = Instance.new("BillboardGui", part)
        bb.Size = UDim2.new(0, 40, 0, 20)
        bb.StudsOffset = Vector3.new(0, 4, 0)
        bb.AlwaysOnTop = true
        bb.LightInfluence = 0

        local lbl = Instance.new("TextLabel", bb)
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = label
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 14
        lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
        lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        lbl.TextStrokeTransparency = 0
        lbl.TextScaled = false

        return part
    end

    local function hasBase()
        local plots = workspace:FindFirstChild("Plots")
        if not plots then return false end
        for _, plot in ipairs(plots:GetChildren()) do
            local sign = plot:FindFirstChild("PlotSign")
            if sign then
                local yb = sign:FindFirstChild("YourBase")
                if yb and yb:IsA("BillboardGui") and yb.Enabled then
                    return true
                end
            end
        end
        return false
    end

    local function showWaypoints()
        for _, p in ipairs(wpParts) do pcall(function() p:Destroy() end) end
        wpParts = {}
        if not hasBase() then return end

        local side = detectMySide()
        local wps = (side == "right") and WP_LEFT or WP_RIGHT

        for i, pos in ipairs(wps) do
            local part = makeWaypointPart(pos, WP_COLORS[i], "P"..i)
            table.insert(wpParts, part)
        end
    end

    local function hideWaypoints()
        for _, p in ipairs(wpParts) do pcall(function() p:Destroy() end) end
        wpParts = {}
    end

    _G._sw_wpOn = makeSwitch(duelsSection, "Show Waypoints", wpOn, function(on)
        wpOn = on
        if on then showWaypoints() else hideWaypoints() end
    end)
    toggleSetters._getShowWaypoints = function() return wpOn end
    toggleSetters._refreshWaypoints = function() if wpOn then showWaypoints() end end

    if wpOn then
        task.spawn(function()
            -- Wait until a base is detected before showing waypoints
            local timeout = 30
            local elapsed = 0
            while elapsed < timeout do
                task.wait(1)
                elapsed += 1
                if hasBase() then
                    showWaypoints()
                    break
                end
            end
        end)
    end
end

